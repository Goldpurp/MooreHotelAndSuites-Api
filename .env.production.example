# Configure these in the cloud secret manager. Do not deploy a .env file.
ASPNETCORE_ENVIRONMENT=Production
# Render's service port is reachable only through its edge. ForwardLimit=1
# consumes only the right-most edge hop, not a client-supplied earlier value.
ForwardedHeaders__Enabled=true
ForwardedHeaders__TrustRenderEdge=true
ForwardedHeaders__ForwardLimit=1
ConnectionStrings__DefaultConnection=Host=<PROD_DB_HOST>;Port=5432;Database=<PROD_DB_NAME>;Username=<LEAST_PRIVILEGED_APP_USER>;Password=<PROD_DB_PASSWORD>;Maximum Pool Size=100;Timeout=10;Command Timeout=30;SSL Mode=VerifyFull;Root Certificate=<CA_CERT_PATH>
Jwt__Key=<PRODUCTION_RANDOM_SECRET_AT_LEAST_32_BYTES>
Jwt__Issuer=MooreHotels
Jwt__Audience=MooreHotels_Clients
Jwt__ExpirationMinutes=60
PublicAppUrl=https://moorehotelandsuites.com
DashboardUrl=https://admin.moorehotelandsuites.com
Api__PublicBaseUrl=https://api.moorehotelandsuites.com
AllowedHosts=api.moorehotelandsuites.com;*.onrender.com
AllowedOrigins__0=https://moorehotelandsuites.com
AllowedOrigins__1=https://www.moorehotelandsuites.com
AllowedOrigins__2=https://admin.moorehotelandsuites.com
CloudinarySettings__CloudName=<PROD_CLOUD_NAME>
CloudinarySettings__ApiKey=<PROD_API_KEY>
CloudinarySettings__ApiSecret=<PROD_API_SECRET>
EmailSettings__ApiPass=<PROD_EMAIL_API_KEY>
EmailSettings__SenderEmail=<PROD_SENDER_EMAIL>
EmailSettings__SenderName=Moore Hotels & Suites
EmailSettings__AdminNotificationEmail=<PROD_ADMIN_EMAIL>
EmailSettings__DeliveryMode=Brevo
EmailSettings__MaxRetryAttempts=3
# Keep disabled until a Monnify account, credentials, webhook and controlled
# payment verification have all passed. DirectTransfer remains available.
MonnifySettings__Enabled=false
# Required only when MonnifySettings__Enabled=true:
MonnifySettings__ApiKey=<PROD_MONNIFY_API_KEY>
MonnifySettings__SecretKey=<PROD_MONNIFY_SECRET>
MonnifySettings__ContractCode=<PROD_MONNIFY_CONTRACT>
MonnifySettings__BaseUrl=https://api.monnify.com
MonnifySettings__EnforceWebhookIpAllowlist=true
MonnifySettings__AllowedWebhookIpAddresses__0=35.242.133.146
BankTransferSettings__BankName=<BANK_NAME>
BankTransferSettings__AccountName=<ACCOUNT_NAME>
BankTransferSettings__AccountNumber=<ACCOUNT_NUMBER>
Runtime__EnableSwagger=false
Runtime__EnableExternalServices=true
Runtime__AutoConfirmEmail=false
Runtime__UseHttpsRedirection=false
Database__ApplyMigrationsOnStartup=false
DataProtection__KeysPath=/var/data/moorehotels-keys
# Use either a mounted PFX path or a base64-encoded PFX secret.
DataProtection__CertificateBase64=<BASE64_ENCODED_DATA_PROTECTION_PFX>
DataProtection__CertificatePassword=<DATA_PROTECTION_CERTIFICATE_PASSWORD>
SeedAdmin=false
