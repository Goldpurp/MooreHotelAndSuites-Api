# Copy to .env.local. This profile is read only when ASPNETCORE_ENVIRONMENT=Local.
ConnectionStrings__DefaultConnection=Host=127.0.0.1;Port=5433;Database=moore_hotels_local;Username=postgres;Password=<LOCAL_POSTGRES_PASSWORD>;Maximum Pool Size=32;Timeout=5;Command Timeout=15;SSL Mode=Disable
Jwt__Key=<GENERATE_AT_LEAST_32_RANDOM_BYTES>
Jwt__Issuer=MooreHotels.Local
Jwt__Audience=MooreHotels.LocalClients
AdminSeed__Name=Moore Hotels Local Super Administrator
AdminSeed__Email=moorehotelandsuites@gmail.com
AdminSeed__Password=<LOCAL_ADMIN_PASSWORD>
EmailSettings__DeliveryMode=Brevo
EmailSettings__ApiPass=<LOCAL_BREVO_API_KEY>
EmailSettings__SenderEmail=<BREVO_VERIFIED_SENDER_EMAIL>
EmailSettings__SenderName=Moore Hotels & Suites
EmailSettings__AdminNotificationEmail=<LOCAL_ADMIN_NOTIFICATION_EMAIL>
EmailSettings__MaxRetryAttempts=3

# Local values override safe appsettings.Local.json defaults when needed.
# Runtime__EnableExternalServices=false
# SeedAdmin=true

# Optional Monnify sandbox exercise. Keep disabled for ordinary Local work.
# Sandbox webhooks do not contain Monnify's production signature, so this API
# deliberately rejects them. Complete the sandbox payment, then use the
# authenticated Admin/Manager verification action in the dashboard.
# Runtime__EnableExternalServices=true
# MonnifySettings__ApiKey=<SANDBOX_MONNIFY_API_KEY>
# MonnifySettings__SecretKey=<SANDBOX_MONNIFY_SECRET>
# MonnifySettings__ContractCode=<SANDBOX_MONNIFY_CONTRACT>
# MonnifySettings__BaseUrl=https://sandbox.monnify.com
