{
  "PublicAppUrl": "http://localhost:3001",
  "DashboardUrl": "http://localhost:3000",
  "Api": {
    "PublicBaseUrl": "http://localhost:5222"
  },
  "AllowedOrigins": [
    "http://localhost:3000",
    "http://127.0.0.1:3000",
    "http://localhost:3001",
    "http://127.0.0.1:3001",
    "http://localhost:8081",
    "http://127.0.0.1:8081"
  ],
  "EmailSettings": {
    "DeliveryMode": "Brevo",
    "SenderName": "Moore Hotels & Suites",
    "MaxRetryAttempts": 3
  },
  "Runtime": {
    "EnableSwagger": true,
    "EnableExternalServices": false,
    "AutoConfirmEmail": true,
    "UseHttpsRedirection": false,
    "ResponseCompression": true,
    "ExternalRequestTimeoutSeconds": 10
  },
  "Database": {
    "CreateIfMissing": true,
    "ApplyMigrationsOnStartup": true,
    "MaxRetryCount": 0,
    "CommandTimeoutSeconds": 15,
    "ContextPoolSize": 32
  },
  "BankTransferSettings": {
    "BankName": "Local Test Bank",
    "AccountName": "Moore Hotels Local Only",
    "AccountNumber": "0000000000"
  },
  "SeedAdmin": true,
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore.Database.Command": "Warning"
    }
  },
  "AllowedHosts": "localhost;127.0.0.1"
}
